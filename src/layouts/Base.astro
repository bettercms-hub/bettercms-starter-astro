---
/** Shared page shell: <head> meta + nav + footer. Marketing pages render their CMS block tree
 *  into the slot; blog/case routes render their own markup. Nav/footer chrome (brand, links,
 *  tagline) reads from the `site` global so it's editable in the CMS — falling back to the
 *  starter defaults when the global is absent. */
import "../styles/global.css";
import { getSingleton, items, type Site } from "../lib/content";

interface Props {
  title?: string;
  description?: string | null;
}
const site = getSingleton<Site>("site");
const brand = site?.brandName ?? "Acme";
const { title = brand, description } = Astro.props;
const NAV = items(site?.navLinks).length
  ? items(site?.navLinks)
  : [
      { label: "Home", href: "/" },
      { label: "Blog", href: "/blog" },
      { label: "Case Studies", href: "/case-studies" },
      { label: "About", href: "/about" },
    ];
const tagline =
  site?.footerTagline ?? "Ship structured content faster. A marketing starter powered by BetterCMS.";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,400..800&family=Hanken+Grotesk:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <nav class="site-nav">
      <a class="brand" href="/">{brand}<span class="dot">.</span></a>
      <div class="links">
        {NAV.map((l) => <a href={l.href}>{l.label}</a>)}
        <a class="bcms-btn bcms-btn-primary" href="/contact">Contact</a>
      </div>
    </nav>
    <slot />
    <footer class="site-footer">
      <div class="site-footer-cols">
        <div class="site-footer-brand">
          <a class="brand" href="/">{brand}<span class="dot">.</span></a>
          <p>{tagline}</p>
        </div>
        <div class="site-footer-col">
          <h4>Explore</h4>
          <ul>{NAV.map((l) => <li><a href={l.href}>{l.label}</a></li>)}</ul>
        </div>
        <div class="site-footer-col">
          <h4>Get started</h4>
          <ul>
            <li><a href="/contact">Contact</a></li>
            <li><a href="https://bettercms.ai" target="_blank" rel="noreferrer">BetterCMS</a></li>
          </ul>
        </div>
      </div>
      <p class="site-footer-copy">© {new Date().getFullYear()} {brand}. Built with BetterCMS.</p>
    </footer>
  </body>
</html>
