---
/** Shared page shell: <head> meta + nav + footer. Marketing pages render their CMS block tree
 *  into the slot; blog/case routes render their own markup. Nav/footer are site chrome, not CMS
 *  content (mirrors the Next starter). */
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string | null;
}
const { title = "Acme", description } = Astro.props;
const NAV = [
  { label: "Home", href: "/" },
  { label: "Blog", href: "/blog" },
  { label: "Case Studies", href: "/case-studies" },
  { label: "About", href: "/about" },
];
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,400..800&family=Hanken+Grotesk:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <nav class="site-nav">
      <a class="brand" href="/">Acme<span class="dot">.</span></a>
      <div class="links">
        {NAV.map((l) => <a href={l.href}>{l.label}</a>)}
        <a class="bcms-btn bcms-btn-primary" href="/contact">Contact</a>
      </div>
    </nav>
    <slot />
    <footer class="site-footer">
      <div class="site-footer-cols">
        <div class="site-footer-brand">
          <a class="brand" href="/">Acme<span class="dot">.</span></a>
          <p>Ship structured content faster. A marketing starter powered by BetterCMS.</p>
        </div>
        <div class="site-footer-col">
          <h4>Explore</h4>
          <ul>{NAV.map((l) => <li><a href={l.href}>{l.label}</a></li>)}</ul>
        </div>
        <div class="site-footer-col">
          <h4>Get started</h4>
          <ul>
            <li><a href="/contact">Contact</a></li>
            <li><a href="https://bettercms.ai" target="_blank" rel="noreferrer">BetterCMS</a></li>
          </ul>
        </div>
      </div>
      <p class="site-footer-copy">© {new Date().getFullYear()} Acme, Inc. Built with BetterCMS.</p>
    </footer>
  </body>
</html>
