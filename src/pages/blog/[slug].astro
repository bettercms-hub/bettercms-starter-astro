---
import Base from "../../layouts/Base.astro";
import BcmsField from "@bettercms-ai/astro/components/BcmsField.astro";
import { listEntries, getEntry, authorData, type BlogPostFields } from "../../lib/content";
import { blogPostingSchema } from "../../lib/seo";

export function getStaticPaths() {
  return listEntries<BlogPostFields>("blog-post").map((e) => ({ params: { slug: e.slug } }));
}

const { slug } = Astro.params;
const post = getEntry<BlogPostFields>("blog-post", slug!);
// getStaticPaths derives its list from this same snapshot, so a miss can only mean the snapshot
// changed under the build. Fail the build rather than emit a blank page. A visitor's bad URL
// never lands here — it never got built — and is served by 404.astro instead.
if (!post) throw new Error(`blog post not found: ${slug}`);

const f = post.data;
const author = authorData(f.author);
const byline = [
  author ? `By ${author.name}${author.role ? `, ${author.role}` : ""}` : null,
  f.publishedDate,
].filter(Boolean).join(" · ");
---

<Base title={f.title} description={f.excerpt} schema={blogPostingSchema(f)}>
  <main id="main">
    <article class="article">
      <a class="back-link" href="/blog">← Back to blog</a>
      <BcmsField path="title"><h1>{f.title}</h1></BcmsField>
      {byline && <p class="byline">{byline}</p>}
      {f.coverImage?.url && <img class="cover" src={f.coverImage.url} alt={f.coverImage.alt ?? ""} data-bcms-field="coverImage" data-bcms-kind="image" />}
      {f.body?.html && <BcmsField path="body" kind="richtext"><div class="prose" set:html={f.body.html} /></BcmsField>}
    </article>
  </main>
</Base>
