---
import Base from "../../layouts/Base.astro";
import { listEntries, type BlogPostFields } from "../../lib/content";
import { brandName } from "../../lib/seo";

const items = listEntries<BlogPostFields>("blog-post");
const brand = brandName();
---

<Base title={`Blog — ${brand}`} description={`Writing from the ${brand} team.`}>
  <main id="main" class="container">
    <header class="page-head">
      <h1>Blog</h1>
      <p>Notes, updates, and what we’re thinking about.</p>
    </header>
    {items.length === 0 ? (
      <p class="empty-note">No published posts yet.</p>
    ) : (
      <div class="card-grid">
        {items.map(({ slug, data }) => (
          <article class="card">
            <a href={`/blog/${slug}`}>
              {data.coverImage?.url && <img class="thumb" src={data.coverImage.url} alt={data.coverImage.alt ?? ""} loading="lazy" />}
              <div class="body">
                {data.publishedDate && <span class="eyebrow">{data.publishedDate}</span>}
                <h3>{data.title}</h3>
                {data.excerpt && <p>{data.excerpt}</p>}
              </div>
            </a>
          </article>
        ))}
      </div>
    )}
  </main>
</Base>
