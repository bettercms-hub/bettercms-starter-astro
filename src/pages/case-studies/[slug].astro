---
import Base from "../../layouts/Base.astro";
import BcmsField from "@bettercms-ai/astro/components/BcmsField.astro";
import { listEntries, getEntry, type CaseStudyFields } from "../../lib/content";
import { caseStudySchema } from "../../lib/seo";

export function getStaticPaths() {
  return listEntries<CaseStudyFields>("case-study").map((e) => ({ params: { slug: e.slug } }));
}

const { slug } = Astro.params;
const cs = getEntry<CaseStudyFields>("case-study", slug!);
// See blog/[slug].astro — a miss is a corrupt snapshot, not a visitor's bad URL.
if (!cs) throw new Error(`case study not found: ${slug}`);

const f = cs.data;
---

<Base title={f.title} description={f.summary} schema={caseStudySchema(f)}>
  <main id="main">
    <article class="article">
      <a class="back-link" href="/case-studies">← Back to case studies</a>
      <BcmsField path="title"><h1>{f.title}</h1></BcmsField>
      {f.client && <BcmsField path="client"><p class="byline">{f.client}</p></BcmsField>}
      {f.coverImage?.url && <img class="cover" src={f.coverImage.url} alt={f.coverImage.alt ?? ""} data-bcms-field="coverImage" data-bcms-kind="image" />}
      {f.summary && <BcmsField path="summary"><p class="prose summary">{f.summary}</p></BcmsField>}
      {f.body?.html && <BcmsField path="body" kind="richtext"><div class="prose" set:html={f.body.html} /></BcmsField>}
    </article>
  </main>
</Base>
